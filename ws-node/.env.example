# Copy this file to .env and fill in the values
# Never commit .env to git

# Must match api/config.php jwt.secret
JWT_SECRET=your_jwt_secret_here

# Strong random string for message cleanup endpoint
CLEANUP_SECRET=your_cleanup_secret_here

# Optional: set to 1 to always log cleanup results in production
CLEANUP_VERBOSE=0

# PHP API base URL (adjust if server IP/path is different)
PHP_API_BASE=http://localhost/campus-chat/api/index.php
